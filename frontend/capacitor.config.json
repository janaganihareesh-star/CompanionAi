{
  "appId": "com.closer.ai",
  "appName": "Companion AI",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "PushNotifications": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#7C3AED",
      "sound": "beep.wav"
    },
    "BackgroundRunner": {
      "label": "com.closer.ai.background",
      "src": "background.js",
      "event": "voice_assistant_listen",
      "repeat": false,
      "autoStart": true
    }
  }
}
